datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [vector]
}

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String
  name            String
  role            UserRole  @default(OWNER)
  phone           String?
  active          Boolean   @default(true)
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?

  // Company Branding (for PDF invoices)
  logoPath        String?   // Path to uploaded logo file
  brandColors     Json?     // Extracted colors: {primary, secondary, accent, background}
  companyName     String?
  companyAddress  String?
  companyPhone    String?
  companyEmail    String?
  companyWebsite  String?
  companyTaxId    String?

  // Relations
  assignedTasks   Task[]    @relation("AssignedTo")
  createdTasks    Task[]    @relation("CreatedBy")
  refreshTokens   RefreshToken[]
  passwordResets  PasswordReset[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([email])
  @@index([role])
  @@index([active])
}

model RefreshToken {
  id              String    @id @default(cuid())
  token           String    @unique
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt       DateTime
  revoked         Boolean   @default(false)
  revokedAt       DateTime?
  replacedBy      String?   // Token that replaced this one (for rotation)

  // Device tracking
  userAgent       String?
  ipAddress       String?

  createdAt       DateTime  @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model PasswordReset {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token           String    @unique
  expiresAt       DateTime
  used            Boolean   @default(false)
  usedAt          DateTime?

  createdAt       DateTime  @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Customer {
  id              String    @id @default(cuid())
  name            String
  email           String?   @unique
  phone           String?   @unique
  company         String?
  nickname        String[]  // Array of nicknames

  // Address
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  zipCode         String?
  coordinates     Json?     // {lat, lng}

  // Billing
  defaultRate     Decimal?
  paymentTerms    String    @default("NET30")
  taxExempt       Boolean   @default(false)

  // Metadata
  notes           String?
  tags            String[]
  customFields    Json?

  // AI Vector Search
  embedding       Unsupported("vector(1536)")?  // OpenAI text-embedding-3-small

  // Relations
  invoices        Invoice[]
  locations       Location[]
  conversations   Conversation[]
  priceOverrides  PriceOverride[]
  quotes          Quote[]
  leads           Lead[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([email])
  @@index([phone])
  @@index([name])
}

model Service {
  id              String    @id @default(cuid())
  name            String
  code            String    @unique
  category        String
  description     String?

  // Pricing
  basePrice       Decimal?
  priceUnit       String?   // "sqft", "hour", "unit"

  // AI Vector Search
  embedding       Unsupported("vector(1536)")?  // OpenAI text-embedding-3-small

  // Relations
  lineItems       LineItem[]
  priceOverrides  PriceOverride[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([code])
  @@index([category])
}

model Invoice {
  id              String    @id @default(cuid())
  invoiceNumber   String    @unique

  // Customer
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id])

  // Location
  locationId      String?
  location        Location? @relation(fields: [locationId], references: [id])
  serviceAddress  String?

  // Dates
  serviceDate     DateTime
  issueDate       DateTime  @default(now())
  dueDate         DateTime
  paidDate        DateTime?

  // Status
  status          InvoiceStatus @default(DRAFT)

  // Financial
  subtotal        Decimal
  taxRate         Decimal   @default(0)
  taxAmount       Decimal   @default(0)
  discount        Decimal   @default(0)
  total           Decimal

  // Content
  lineItems       LineItem[]
  notes           String?
  terms           String?

  // Files
  pdfUrl          String?
  pdfData         Bytes?

  // Source
  source          String?   // "voice", "telegram", "web", "cli"
  sourceMessageId String?

  // Relations
  receipts        Receipt[]
  check           Check?
  conversations   Conversation[]
  quotes          Quote[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sentAt          DateTime?

  @@index([customerId])
  @@index([status])
  @@index([serviceDate])
  @@index([invoiceNumber])
}

model LineItem {
  id              String    @id @default(cuid())
  invoiceId       String
  invoice         Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  serviceId       String?
  service         Service?  @relation(fields: [serviceId], references: [id])

  description     String
  quantity        Decimal
  unit            String?
  rate            Decimal
  amount          Decimal

  order           Int

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([invoiceId])
}

model Receipt {
  id              String    @id @default(cuid())
  invoiceId       String?
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id])
  userId          String?

  // File
  imageUrl        String?
  imageData       Bytes?

  // Extracted Data
  vendor          String
  amount          Decimal
  date            DateTime
  category        String?
  items           Json?     // Array of items
  ocrData         Json?     // Raw OCR result

  // Payment Information
  paymentMethod   String?   // "credit_card", "debit_card", "cash", "check", "other"
  cardLast4       String?   // Last 4 digits if card payment
  cardBrand       String?   // "visa", "mastercard", "amex", etc.

  // Business Purpose / Notes
  notes           String?   // For business meals: who you met, what was discussed, etc.

  // Metadata
  status          String    @default("pending") // "pending", "processed", "review_needed"
  processed       Boolean   @default(false)
  confidence      Float?    // OCR confidence

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([invoiceId])
  @@index([vendor])
  @@index([date])
  @@index([userId])
  @@index([paymentMethod])
}

model Check {
  id              String    @id @default(cuid())
  invoiceId       String?   @unique
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id])
  userId          String?

  // File
  imageUrl        String?
  imageData       Bytes?

  // Extracted Check Data
  checkNumber     String
  amount          Decimal
  date            DateTime
  payee           String?
  memo            String?
  ocrData         Json?     // Raw OCR result

  // Matching & Processing
  status          String    @default("pending") // "pending", "matched", "processed", "review_needed"
  matchedAt       DateTime?
  confidence      Float?    // OCR confidence
  processed       Boolean   @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([invoiceId])
  @@index([checkNumber])
  @@index([date])
  @@index([userId])
  @@index([amount])
}

model Conversation {
  id              String    @id @default(cuid())
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])
  invoiceId       String?
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id])

  // Channel
  channel         String    // "telegram", "voice", "web", "cli"
  channelUserId   String?

  // Content
  messages        Message[]
  context         Json?     // Conversation context

  // Status
  status          String    @default("active")

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([customerId])
  @@index([channelUserId])
}

model Message {
  id              String    @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role            String    // "user", "assistant", "system"
  content         String

  // For voice messages
  audioUrl        String?
  transcription   String?

  // AI Processing
  intent          Json?     // Parsed intent
  entities        Json?     // Extracted entities
  confidence      Float?

  createdAt       DateTime  @default(now())

  @@index([conversationId])
}

model Location {
  id              String    @id @default(cuid())
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id])

  name            String
  addressLine1    String
  addressLine2    String?
  city            String
  state           String
  zipCode         String

  coordinates     Json?     // {lat, lng}

  // Size/Details
  squareFeet      Int?
  notes           String?
  accessCodes     String?

  invoices        Invoice[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([customerId])
}

model PriceOverride {
  id              String    @id @default(cuid())
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id])
  serviceId       String
  service         Service   @relation(fields: [serviceId], references: [id])

  price           Decimal
  unit            String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([customerId, serviceId])
}

model AIInteraction {
  id              String    @id @default(cuid())

  // Request
  input           String
  model           String
  provider        String    // "openai", "anthropic", "ollama"

  // Response
  output          Json
  tokensUsed      Int?
  cost            Decimal?
  latencyMs       Int?

  // Status
  success         Boolean
  error           String?

  createdAt       DateTime  @default(now())

  @@index([provider])
  @@index([createdAt])
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// LEAD MANAGEMENT & SCHEDULING - NEW FEATURES
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Lead {
  id              String    @id @default(cuid())
  userId          String?

  // Contact Info
  name            String
  phone           String
  email           String?
  source          String    @default("sms") // "sms", "call", "email", "web", "referral"

  // Lead Details
  message         String?   // Initial message/inquiry
  projectType     String?   // "hydroseed", "lawn-mowing", "fertilizer", etc.
  estimatedArea   Int?      // Square footage
  estimatedValue  Decimal?  // Potential $ value

  // Status Tracking
  status          LeadStatus @default(NEW)
  priority        Priority   @default(MEDIUM)

  // Follow-up Tracking
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  followUpCount   Int       @default(0)

  // Conversion
  convertedToCustomerId String?
  convertedToCustomer   Customer? @relation(fields: [convertedToCustomerId], references: [id])
  convertedToQuoteId    String?   @unique
  convertedToQuote      Quote?    @relation("LeadConversion", fields: [convertedToQuoteId], references: [id])
  convertedAt     DateTime?

  // Relations
  reminders       Reminder[]
  followUps       FollowUp[]
  quotes          Quote[]   @relation("LeadQuotes")
  notes           LeadNote[]

  // Metadata
  tags            String[]
  customFields    Json?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([phone])
  @@index([status])
  @@index([nextFollowUpAt])
  @@index([createdAt])
}

model Reminder {
  id              String    @id @default(cuid())
  leadId          String
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId          String?

  // Reminder Details
  title           String
  description     String?
  remindAt        DateTime

  // Status
  status          ReminderStatus @default(PENDING)
  completedAt     DateTime?
  snoozedUntil    DateTime?

  // Notification
  notifyVia       String[]  // ["sms", "email", "push", "in-app"]
  notifiedAt      DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([leadId])
  @@index([remindAt])
  @@index([status])
}

model FollowUp {
  id              String    @id @default(cuid())
  leadId          String
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId          String?

  // Follow-up Details
  type            FollowUpType
  scheduledFor    DateTime
  message         String?   // Pre-written message template

  // Status
  status          FollowUpStatus @default(SCHEDULED)
  attemptedAt     DateTime?
  completedAt     DateTime?

  // Result
  contacted       Boolean   @default(false)
  response        String?   // What they said
  outcome         String?   // "interested", "not-interested", "callback-later", "converted"

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([leadId])
  @@index([scheduledFor])
  @@index([status])
}

model Quote {
  id              String    @id @default(cuid())
  quoteNumber     String    @unique
  leadId          String?
  lead            Lead?     @relation("LeadQuotes", fields: [leadId], references: [id])
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])
  userId          String?

  // Reverse relation for lead conversion
  convertedFromLead Lead?   @relation("LeadConversion")

  // Project Details
  projectType     String    // "hydroseed", "lawn-mowing", etc.
  area            Int?      // Square footage
  description     String?

  // Pricing
  lineItems       QuoteLineItem[]
  subtotal        Decimal
  taxRate         Decimal   @default(0)
  taxAmount       Decimal   @default(0)
  discount        Decimal   @default(0)
  total           Decimal

  // Validity
  validUntil      DateTime
  expiresAt       DateTime?

  // Status
  status          QuoteStatus @default(DRAFT)
  sentAt          DateTime?
  viewedAt        DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?

  // Conversion
  convertedToInvoiceId String?
  convertedToInvoice   Invoice? @relation(fields: [convertedToInvoiceId], references: [id])
  convertedAt     DateTime?

  // Files
  pdfUrl          String?

  // Metadata
  notes           String?
  terms           String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([leadId])
  @@index([customerId])
  @@index([status])
  @@index([validUntil])
}

model QuoteLineItem {
  id              String    @id @default(cuid())
  quoteId         String
  quote           Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  description     String
  quantity        Decimal
  unit            String?   // "sqft", "hour", "unit"
  rate            Decimal
  amount          Decimal

  order           Int

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([quoteId])
}

model LeadNote {
  id              String    @id @default(cuid())
  leadId          String
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId          String?

  content         String
  type            String    @default("note") // "note", "call", "meeting", "email"

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([leadId])
  @@index([createdAt])
}

// SMS/Communication Log
model SmsMessage {
  id              String    @id @default(cuid())
  userId          String?
  leadId          String?

  // Message Details
  from            String    // Phone number
  to              String    // Phone number
  body            String
  direction       Direction // INBOUND or OUTBOUND

  // Twilio Data
  twilioSid       String?   @unique
  status          String?   // "queued", "sent", "delivered", "failed"
  errorCode       String?
  errorMessage    String?

  // Metadata
  mediaUrls       String[]  // Attached images

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([leadId])
  @@index([from])
  @@index([to])
  @@index([createdAt])
}

// Enums for Lead Management
enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  QUOTED
  NEGOTIATING
  WON
  LOST
  DEAD
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ReminderStatus {
  PENDING
  SNOOZED
  COMPLETED
  CANCELLED
}

enum FollowUpType {
  INITIAL_CONTACT
  FOLLOW_UP_1
  FOLLOW_UP_2
  FOLLOW_UP_3
  FINAL_ATTEMPT
  CUSTOM
}

enum FollowUpStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  SKIPPED
  FAILED
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

enum Direction {
  INBOUND
  OUTBOUND
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// TEAM & TASK MANAGEMENT
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Task {
  id              String    @id @default(cuid())

  // What needs to be done
  title           String
  description     String?
  type            TaskType  @default(FOLLOW_UP)

  // Assignment
  assignedToId    String?
  assignedTo      User?     @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdById     String
  createdBy       User      @relation("CreatedBy", fields: [createdById], references: [id])

  // References
  leadId          String?
  customerId      String?
  invoiceId       String?

  // Scheduling
  dueDate         DateTime?
  scheduledFor    DateTime?
  completedAt     DateTime?

  // Status
  status          TaskStatus @default(TODO)
  priority        Priority   @default(MEDIUM)

  // Notes
  notes           String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([assignedToId])
  @@index([createdById])
  @@index([status])
  @@index([dueDate])
  @@index([scheduledFor])
  @@index([leadId])
  @@index([customerId])
  @@index([invoiceId])
}

enum UserRole {
  OWNER
  ADMIN
  EMPLOYEE
  VIEWER
}

enum TaskType {
  FOLLOW_UP
  QUOTE
  SCHEDULE_JOB
  CALL_CUSTOMER
  SEND_INVOICE
  COLLECT_PAYMENT
  SITE_VISIT
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  WAITING
  COMPLETED
  CANCELLED
}
