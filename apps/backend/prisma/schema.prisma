// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// TEAM & TASK MANAGEMENT
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Task {
  id              String    @id @default(cuid())

  // What needs to be done
  title           String
  description     String?
  type            TaskType  @default(FOLLOW_UP)

  // Assignment
  assignedToId    String?
  assignedTo      User?     @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdById     String
  createdBy       User      @relation("CreatedBy", fields: [createdById], references: [id])

  // References
  leadId          String?
  customerId      String?
  invoiceId       String?

  // Scheduling
  dueDate         DateTime?
  scheduledFor    DateTime?
  completedAt     DateTime?

  // Status
  status          TaskStatus @default(TODO)
  priority        Priority   @default(MEDIUM)

  // Notes
  notes           String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([assignedToId])
  @@index([createdById])
  @@index([status])
  @@index([dueDate])
  @@index([scheduledFor])
  @@index([leadId])
  @@index([customerId])
  @@index([invoiceId])
}

enum UserRole {
  OWNER
  ADMIN
  EMPLOYEE
  VIEWER
}

enum TaskType {
  FOLLOW_UP
  QUOTE
  SCHEDULE_JOB
  CALL_CUSTOMER
  SEND_INVOICE
  COLLECT_PAYMENT
  SITE_VISIT
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  WAITING
  COMPLETED
  CANCELLED
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// DOUBLE-ENTRY ACCOUNTING SYSTEM
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum BalanceType {
  DEBIT
  CREDIT
}

enum JournalStatus {
  DRAFT
  POSTED
  VOIDED
}

enum JournalSourceType {
  INVOICE
  RECEIPT
  CHECK
  MANUAL
  ADJUSTMENT
  OPENING_BALANCE
  TRANSFER
}

model Account {
  id              String      @id @default(cuid())

  // Multi-tenancy
  userId          String

  // Account identification
  code            String                // Account number (e.g., "1000", "4100")
  name            String                // Account name (e.g., "Cash", "Accounts Receivable")
  accountType     AccountType
  balanceType     BalanceType           // Natural balance side

  // Hierarchy
  parentId        String?
  parent          Account?    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children        Account[]   @relation("AccountHierarchy")
  level           Int         @default(0)

  // Balance tracking
  balance         Decimal     @default(0)
  balanceAsOf     DateTime    @default(now())

  // Configuration
  active          Boolean     @default(true)
  systemAccount   Boolean     @default(false)  // System-managed (AR, revenue, etc.)
  allowManualEntries Boolean  @default(true)

  // Tax configuration
  taxEnabled      Boolean     @default(false)
  taxRate         Decimal?

  // Metadata
  description     String?
  notes           String?
  tags            String[]

  // Relations
  journalLines    JournalLine[]
  expenseCategories ExpenseCategory[]
  linkedBankAccounts BankAccount[]     // Bank/CC accounts linked to this Chart of Accounts entry
  linkedTaxAccounts TaxAccount[]       // Tax categories linked to this Chart of Accounts entry

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([userId, code])
  @@index([userId])
  @@index([userId, accountType])
  @@index([accountType])
  @@index([parentId])
  @@index([active])
  @@index([systemAccount])
}

model JournalEntry {
  id              String            @id @default(cuid())

  // Multi-tenancy
  userId          String

  // Entry identification
  entryNumber     String                     // Sequential journal entry number
  entryDate       DateTime                   // Transaction date

  // Status
  status          JournalStatus     @default(DRAFT)
  postedAt        DateTime?
  postedBy        String?
  voidedAt        DateTime?
  voidedBy        String?
  voidReason      String?

  // Source tracking
  sourceType      JournalSourceType
  sourceId        String?                    // ID of source document (invoice, receipt, etc.)
  referenceNumber String?                    // External reference (invoice #, check #, etc.)

  // Description
  description     String
  notes           String?

  // Lines
  lines           JournalLine[]

  // Metadata
  tags            String[]
  customFields    Json?

  // User tracking
  createdBy       String?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([userId, entryNumber])
  @@index([userId])
  @@index([userId, entryDate])
  @@index([userId, status])
  @@index([entryDate])
  @@index([status])
  @@index([sourceType, sourceId])
  @@index([createdBy])
}

model JournalLine {
  id              String        @id @default(cuid())
  
  // Entry reference
  journalEntryId  String
  journalEntry    JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  
  // Account reference
  accountId       String
  account         Account       @relation(fields: [accountId], references: [id])
  
  // Amount
  debit           Decimal       @default(0)
  credit          Decimal       @default(0)
  
  // Entity tracking (customer, vendor, etc.)
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  
  // Line details
  description     String?
  lineOrder       Int           @default(0)
  
  // Metadata
  tags            String[]
  
  createdAt       DateTime      @default(now())
  
  @@index([journalEntryId])
  @@index([accountId])
  @@index([customerId])
}

model ExpenseCategory {
  id              String    @id @default(cuid())

  // Multi-tenancy
  userId          String

  // Category identification
  name            String
  code            String?

  // Accounting integration
  accountId       String?
  account         Account?  @relation(fields: [accountId], references: [id])

  // Hierarchy
  parentId        String?
  parent          ExpenseCategory? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children        ExpenseCategory[] @relation("CategoryHierarchy")

  // Configuration
  active          Boolean   @default(true)
  requiresReceipt Boolean   @default(true)
  taxDeductible   Boolean   @default(true)

  // IRS/Tax categorization
  taxCategory     String?   // IRS Schedule C category
  description     String?

  // Relations
  receipts        Receipt[]

  // Metadata
  notes           String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, name])
  @@unique([userId, code])
  @@index([userId])
  @@index([accountId])
  @@index([parentId])
  @@index([active])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// BANK TRANSACTION & TAX REPORTING SYSTEM
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Company {
  id              String    @id @default(cuid())
  userId          String

  // Company Info
  name            String
  legalName       String?
  taxId           String?   // EIN
  taxType         String?   // "S-Corp", "LLC", "Sole Proprietor"
  fiscalYearStart String    @default("01-01") // MM-DD format

  // Address
  address         String?
  city            String?
  state           String?
  zipCode         String?

  // Settings
  active          Boolean   @default(true)

  // Relations
  bankAccounts    BankAccount[]
  taxAccounts     TaxAccount[]
  categorizationRules CategorizationRule[]
  bankTransactions BankTransaction[]
  vendors         Vendor[]
  reconciliationLogs ReconciliationLog[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([active])

  // Business OS relations (spec §3.1)
  primaryCustomers Customer[] @relation("CustomerPrimaryCompany")
  invoices         Invoice[]
  leads            Lead[]
  quotes           Quote[]
  revenueEvents    RevenueEvent[]
  activities       Activity[]
  jobs             Job[]
  products         Product[]
  orders           Order[]
  ingestSources    IngestSource[]
  subscriptions    Subscription[]
}

model TaxAccount {
  id              String    @id @default(cuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Account Info
  code            String    // "1010", "4010", "6100"
  name            String    // "Cash - Operating", "Gross Receipts"
  accountType     TaxAccountType

  // Tax Treatment
  taxTreatment    String    // "100%", "50%", "NON_DEDUCTIBLE", "TRANSFER"
  scheduleC       String?   // IRS form line number (for Schedule C/Form 1120-S)

  // Configuration
  active          Boolean   @default(true)
  isSystemAccount Boolean   @default(false)

  // Link to Chart of Accounts (unifies the two account systems)
  linkedAccountId String?
  linkedAccount   Account?  @relation(fields: [linkedAccountId], references: [id])

  // Relations
  bankTransactions BankTransaction[]
  categorizationRules CategorizationRule[]
  vendorDefaults  Vendor[]                // Vendors that use this as default category

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
  @@index([accountType])
  @@index([taxTreatment])
}

model BankAccount {
  id              String    @id @default(cuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Account Info
  name            String    // "Operating Account", "Payroll Account"
  accountNumber   String?   // Last 4 digits (e.g., "0055")
  bankName        String?
  accountType     String    @default("checking") // "checking", "savings", "credit_card"

  // Link to Chart of Accounts
  linkedAccountId String?   // Links to Account (Asset for checking/savings, Liability for credit cards)
  linkedAccount   Account?  @relation(fields: [linkedAccountId], references: [id])

  // Balance Tracking
  currentBalance  Decimal   @default(0)
  balanceAsOf     DateTime  @default(now())

  // Configuration
  active          Boolean   @default(true)
  isPrimary       Boolean   @default(false)  // Primary account for the company

  // Relations
  transactions    BankTransaction[]
  vendorDefaults  Vendor[]           // Vendors that use this as default bank account

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([companyId, accountNumber])
  @@index([companyId])
  @@index([active])
  @@index([linkedAccountId])
}

model CategorizationRule {
  id              String    @id @default(cuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Rule Info
  name            String

  // Matching Logic
  matchType       MatchType // CONTAINS, STARTS_WITH, EXACT, REGEX
  matchValue      String

  // Target Category
  taxAccountId    String
  taxAccount      TaxAccount @relation(fields: [taxAccountId], references: [id])

  // Optional: Link to Vendor (when rule matches, also assign vendor)
  vendorId        String?
  vendor          Vendor?    @relation(fields: [vendorId], references: [id])

  // Priority & Control
  priority        Int       @default(0) // Higher priority = applied first
  enabled         Boolean   @default(true)
  autoCreated     Boolean   @default(false) // Created from user manual categorization

  // Statistics
  timesMatched    Int       @default(0)
  lastMatchedAt   DateTime?

  // Relations
  transactions    BankTransaction[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId])
  @@index([enabled])
  @@index([priority])
}

model BankTransaction {
  id              String    @id @default(cuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Bank Account
  bankAccountId   String
  bankAccount     BankAccount @relation(fields: [bankAccountId], references: [id])

  // Transaction Details
  date            DateTime
  description     String
  amount          Decimal   @db.Decimal(10, 2) // Negative for expenses, positive for income
  balance         Decimal   @db.Decimal(10, 2) // Balance after transaction

  // Categorization
  taxAccountId    String?
  taxAccount      TaxAccount? @relation(fields: [taxAccountId], references: [id])

  matchedRuleId   String?
  matchedRule     CategorizationRule? @relation(fields: [matchedRuleId], references: [id])

  // Manual Override
  isManualCategorization Boolean @default(false)
  needsReview     Boolean   @default(true)

  // Vendor Tracking
  vendorId        String?
  vendor          Vendor?   @relation(fields: [vendorId], references: [id])
  vendorRaw       String?   // Original from bank: "AMAZON.COM*MF4Y"

  // Split Transaction Support
  parentId        String?   // If this is a split child
  parent          BankTransaction? @relation("SplitParent", fields: [parentId], references: [id], onDelete: Cascade)
  splits          BankTransaction[] @relation("SplitParent")
  isSplit         Boolean   @default(false)  // True if this is a split parent
  splitIndex      Int?      // Order within split group (for children)

  // Optional Links
  invoiceId       String?   // Link to existing Invoice
  receiptId       String?   // Link to existing Receipt

  // Metadata
  notes           String?
  tags            String[]

  // Import tracking
  importSource    String?   // "csv", "json", "pdf_vision", "manual"
  importBatchId   String?   // Group transactions from same import

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId])
  @@index([bankAccountId])
  @@index([date])
  @@index([taxAccountId])
  @@index([needsReview])
  @@index([importBatchId])
  @@index([vendorId])
  @@index([parentId])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// VENDOR MANAGEMENT & SPLIT TRANSACTIONS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Vendor {
  id              String    @id @default(cuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Vendor Info
  name            String                // "Amazon", "Shell", "Home Depot"
  matchPatterns   String[]              // ["AMAZON", "AMZN"] - patterns to auto-detect

  // Optional Defaults
  defaultBankAccountId  String?         // Which card typically used for this vendor
  defaultBankAccount    BankAccount?    @relation(fields: [defaultBankAccountId], references: [id])
  defaultTaxAccountId   String?         // Default category (if single-category vendor)
  defaultTaxAccount     TaxAccount?     @relation(fields: [defaultTaxAccountId], references: [id])

  // Flags
  requiresSplit   Boolean   @default(false)  // True for Amazon (usually multi-category)
  isActive        Boolean   @default(true)

  // Metadata
  notes           String?   // "Usually office supplies + personal mixed"

  // Relations
  transactions    BankTransaction[]
  categorizationRules CategorizationRule[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
  @@index([isActive])
}

// Enums for Bank Transaction System
enum TaxAccountType {
  ASSET
  LIABILITY
  EQUITY
  EQUITY_CONTRA    // Owner draws/distributions - reduces equity
  INCOME
  EXPENSE_COGS
  EXPENSE_OPERATING
  TRANSFER         // Internal transfers - excluded from reports
}

enum MatchType {
  CONTAINS
  STARTS_WITH
  EXACT
  REGEX
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// VISION WEALTH OS - RECONCILIATION
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model ReconciliationLog {
  id            String   @id @default(cuid())
  companyId     String
  throughDate   DateTime @db.Date
  source        String   // 'manual' | 'statement_match'
  writtenBy     String
  writtenAt     DateTime @default(now()) @db.Timestamptz(6)
  note          String?

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, throughDate])
  @@index([companyId, throughDate(sort: Desc)])
  @@map("reconciliation_log")
}

// ============ Business OS (Phase 1) ============

enum RevenueEngine {
  FIELD_SERVICE // Donovan Farms jobs
  SUBSCRIPTION  // Business Builders recurring
  COMMERCE      // online product sales
  SERVICES      // generic invoiced work (legacy/default)
  OTHER         // partnerships, licensing, manual
}

enum RevenueEventType {
  INVOICE_PAYMENT
  ORDER_PAYMENT
  SUBSCRIPTION_RENEWAL
  REFUND
  ADJUSTMENT
}

enum ActivityType {
  CALL
  EMAIL
  SMS
  MEETING
  SITE_VISIT
  NOTE
  SYSTEM
}

enum ActivityDirection {
  INBOUND
  OUTBOUND
}

// ============ NEW MODELS ============

// The Revenue Event spine (docs/BUSINESS_OS_SPEC.md §3.2). Written ONLY by
// services/revenue-events.ts. Unique constraint = idempotency.
model RevenueEvent {
  id          String           @id @default(cuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  customerId  String?
  customer    Customer?        @relation(fields: [customerId], references: [id])
  engine      RevenueEngine
  eventType   RevenueEventType
  sourceType  String           // "invoice" | "order" | "subscription" | "manual" | future
  sourceId    String
  amount      Decimal          // negative for REFUND
  currency    String           @default("USD")
  occurredAt  DateTime
  description String?
  // first-touch attribution snapshot (Phase 5 fills these)
  attributionSource   String?
  attributionCampaign String?
  metadata    Json?
  createdAt   DateTime         @default(now())

  @@unique([sourceType, sourceId, eventType])
  @@index([companyId, occurredAt])
  @@index([customerId])
  @@index([engine, occurredAt])
}

// Activity + communications log (spec §3.3)
model Activity {
  id         String             @id @default(cuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId  String?
  company    Company?           @relation(fields: [companyId], references: [id])
  customerId String?
  customer   Customer?          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  leadId     String?
  lead       Lead?              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type       ActivityType
  direction  ActivityDirection?
  subject    String?
  body       String
  occurredAt DateTime           @default(now())
  source     String             @default("manual") // "manual" | "api" | "eve" | "automation" | "system"
  metadata   Json?
  createdAt  DateTime           @default(now())

  @@index([customerId, occurredAt])
  @@index([leadId, occurredAt])
  @@index([companyId, occurredAt])
  @@index([userId, occurredAt])
}

// ============ Business OS (Phase 2): field-service jobs ============

enum JobStatus {
  REQUESTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CLOSED
  CANCELLED
}

// Field-service job (spec §3.4): Request -> Quote -> Job -> Closeout -> auto-Invoice.
// CLOSED requires closeout and creates the linked Invoice; payment of that
// invoice emits the FIELD_SERVICE RevenueEvent (jobs never write the spine).
model Job {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id])
  customerId     String
  customer       Customer  @relation(fields: [customerId], references: [id])
  locationId     String?
  location       Location? @relation(fields: [locationId], references: [id])
  quoteId        String?
  quote          Quote?    @relation(fields: [quoteId], references: [id])

  jobNumber      String
  title          String
  description    String?
  status         JobStatus @default(REQUESTED)

  // Scheduling + route/day view
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  routeOrder     Int?

  // Costing
  estimatedCost  Decimal?
  actualCost     Decimal?

  // Closeout (the crew packet)
  completedAt    DateTime?
  closeoutNotes  String?
  checklist      Json?     // [{item, done, doneAt, by}]
  customerNotes  String?

  invoiceId      String?   @unique
  invoice        Invoice?  @relation(fields: [invoiceId], references: [id])

  assignments    JobAssignment[]
  photos         JobPhoto[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, jobNumber])
  @@index([companyId, status])
  @@index([scheduledStart])
  @@index([customerId])
}

model JobAssignment {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String?  // "lead" | "crew"
  createdAt DateTime @default(now())

  @@unique([jobId, userId])
  @@index([userId])
}

model JobPhoto {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  imageUrl  String?
  imageData Bytes?
  caption   String?
  phase     String   @default("after") // "before" | "during" | "after"
  takenAt   DateTime @default(now())

  @@index([jobId])
}

// ============ Business OS (Phase 3): commerce ============

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  PARTIALLY_REFUNDED
  REFUNDED
  CANCELLED
}

// Inventory-lite product catalog (spec §3.5): a stock counter, not a WMS.
model Product {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id])
  sku               String
  name              String
  description       String?
  price             Decimal
  cogs              Decimal?
  stockQty          Int      @default(0)
  lowStockThreshold Int      @default(0) // 0 = no restock alerts
  active            Boolean  @default(true)
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  orderItems        OrderItem[]

  @@unique([companyId, sku])
  @@index([companyId, active])
}

// Orders ingested from online stores (spec §3.5/3.6). Idempotent on
// (companyId, source, externalId); PAID auto-creates Invoice + RevenueEvent.
model Order {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId      String
  company        Company     @relation(fields: [companyId], references: [id])
  customerId     String?
  customer       Customer?   @relation(fields: [customerId], references: [id])
  source         String      // IngestSource.key ("stripe" | "shopify" | site key)
  externalId     String
  status         OrderStatus
  currency       String      @default("USD")
  subtotal       Decimal     @default(0)
  taxAmount      Decimal     @default(0)
  shippingAmount Decimal     @default(0)
  discountAmount Decimal     @default(0)
  total          Decimal
  refundedAmount Decimal     @default(0)
  placedAt       DateTime
  paidAt         DateTime?
  fulfilledAt    DateTime?
  invoiceId      String?     @unique
  invoice        Invoice?    @relation(fields: [invoiceId], references: [id])
  // first-touch attribution (spec §3.8; Lead gets the same block in Phase 5)
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmTerm        String?
  utmContent     String?
  landingPage    String?
  referrer       String?
  needsReview    Boolean     @default(false) // unknown SKU / unmatched customer
  rawPayload     Json
  items          OrderItem[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([companyId, source, externalId])
  @@index([companyId, placedAt])
  @@index([customerId])
  @@index([status])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  sku       String
  name      String
  quantity  Int
  unitPrice Decimal
  unitCogs  Decimal? // snapshot of Product.cogs at ingestion

  @@index([orderId])
  @@index([productId])
}

// Per-store webhook credentials (spec §3.6)
model IngestSource {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id])
  key        String    @unique // :sourceKey in the webhook URL
  name       String
  kind       String    // "stripe" | "shopify" | "custom"
  secret     String    // HMAC-SHA256 secret
  active     Boolean   @default(true)
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([companyId])
}

// ============ Business OS (Phase 4): recurring revenue ============

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  PAUSED
  CANCELLED
}

enum BillingInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

// Recurring revenue (spec §3.7): renewals create PAID invoices (source
// "subscription") and SUBSCRIPTION_RENEWAL revenue events; dunning and churn
// flags drive the Phase 6 automations.
model Subscription {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId         String
  company           Company            @relation(fields: [companyId], references: [id])
  customerId        String
  customer          Customer           @relation(fields: [customerId], references: [id])
  leadId            String?            // origin of the deal
  lead              Lead?              @relation(fields: [leadId], references: [id])

  name              String             // "Acme — hosting + automation"
  status            SubscriptionStatus @default(ACTIVE)
  interval          BillingInterval    @default(MONTHLY)
  amount            Decimal            // per interval
  currency          String             @default("USD")

  startDate         DateTime
  currentPeriodEnd  DateTime           // next renewal due date
  cancelAtPeriodEnd Boolean            @default(false)
  cancelledAt       DateTime?

  churnRisk         Boolean            @default(false)
  churnReason       String?
  dunningStage      Int                @default(0) // 0 none; 1..3 escalating
  lastPaymentAt     DateTime?
  externalRef       String?            // e.g. Stripe subscription id
  notes             String?

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([companyId, status])
  @@index([currentPeriodEnd])
  @@index([customerId])
}
