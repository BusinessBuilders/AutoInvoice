{
  "expo": {
    "name": "AutoInvoice",
    "slug": "autoinvoice",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.autoinvoice.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.autoinvoice.app",
      "permissions": [
        "READ_SMS",
        "SEND_SMS",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "READ_CONTACTS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow AutoInvoice to access your calendar for scheduling follow-ups."
        }
      ],
      [
        "expo-sms",
        {
          "smsPermission": "Allow AutoInvoice to read messages for lead management."
        }
      ]
    ],
    "scheme": "autoinvoice",
    "experiments": {
      "typedRoutes": true
    }
  }
}
